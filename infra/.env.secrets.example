# Secrets for the `api` + `postgres` compose services. Copy to `infra/.env.secrets`
# (gitignored) and fill in real values — both locally and on the production
# server, next to docker-compose.yml. Compose loads this via `env_file`.

# Postgres password — used by the `postgres` service and the API's DB login.
POSTGRES_PASSWORD=change-me

# Secret for signing session JWTs. Use a long random value:
#   openssl rand -hex 32
JWT_SECRET=change-me

# Cloudflare API token for Caddy's DNS-01 TLS challenge. Scope: Zone → DNS → Edit
# and Zone → Zone → Read, limited to the atlasfsm.com zone.
CLOUDFLARE_API_TOKEN=change-me
