# Caddy auto-provisions Let's Encrypt TLS for every site block below. Certs are
# issued/renewed via the ACME DNS-01 challenge using a Cloudflare API token
# (acme_dns below), which proves domain ownership through a DNS TXT record. That
# works regardless of proxy status, so all records can stay proxied (orange) —
# no more grey-clouding to issue certs. Requires the caddy-dns/cloudflare module
# (see infra/caddy/Dockerfile) and CLOUDFLARE_API_TOKEN in the environment.
{
	email {$ACME_EMAIL}
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

# Canonical host — the public marketing site.
www.{$DOMAIN} {
	encode zstd gzip
	reverse_proxy public:3000
}

# Apex → www, so there is a single canonical host.
{$DOMAIN} {
	redir https://www.{$DOMAIN}{uri} permanent
}

# Admin console — the authenticated SaaS workspace (apps/harmony).
harmony.{$DOMAIN} {
	encode zstd gzip
	reverse_proxy harmony:3000
}

# Core product — the authenticated end-user workspace (apps/app).
app.{$DOMAIN} {
	encode zstd gzip
	reverse_proxy app:3000
}

# Shared backend — the API the three UIs consume (apps/api).
api.{$DOMAIN} {
	encode zstd gzip
	reverse_proxy api:3000
}

# Shared login / IAM — same apps/api service; issues the .{$DOMAIN} session
# cookie so a single sign-in covers both app. and harmony.
iam.{$DOMAIN} {
	encode zstd gzip
	reverse_proxy api:3000
}

# ── Future apps (separate codebases) attach here as subdomains. To add one:
#   1. add its service to docker-compose.yml (e.g. `foo`, expose 3000)
#   2. add a site block like `app.{$DOMAIN}` above (reverse_proxy foo:3000)
#   3. add an A record for the subdomain in Cloudflare
